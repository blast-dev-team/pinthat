{
  "manifest_version": 3,
  "name": "PinThat",
  "version": "3.0.0",
  "description": "Pin it, remember it, share it — visual QA feedback tool",
  "permissions": ["activeTab", "storage", "clipboardWrite", "identity"],
  "host_permissions": ["https://api.github.com/*", "https://pinthat-auth.el-lee.workers.dev/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-qa": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Toggle QA inspection mode"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
