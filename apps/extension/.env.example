# Copy to .env.local and fill in.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe Payment Link for the lifetime access plan. Must be configured
# to COLLECT customer email — the webhook matches entitlements by the
# email collected here. Use a buy.stripe.com/test_... link for dev and
# a buy.stripe.com/... link for prod builds.
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_your-link
